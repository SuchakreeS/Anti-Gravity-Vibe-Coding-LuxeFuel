generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  ADMIN
  DRIVER
  USER
  INDIVIDUAL
}

model Organization {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  plan      Plan       @default(FREE)
  users     User[]
  cars      Car[]
  auditLogs AuditLog[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model User {
  id             Int           @id @default(autoincrement())
  email          String        @unique
  password       String
  name           String
  role           Role          @default(INDIVIDUAL)
  plan           Plan          @default(FREE)
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  cars           Car[]
  fuelRecords    FuelRecord[]
  auditLogs      AuditLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Car {
  id                  Int           @id @default(autoincrement())
  name                String
  brand               String
  model               String
  licensePlate        String?
  otherSpecs          String?
  isPersonal          Boolean       @default(false)
  lastServiceMileage  Float         @default(0)
  serviceInterval     Float         @default(10000)
  userId              Int?
  user                User?         @relation(fields: [userId], references: [id])
  organizationId      Int?
  organization        Organization? @relation(fields: [organizationId], references: [id])
  fuelRecords         FuelRecord[]
  maintenanceData     String?       @db.Text
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model FuelRecord {
  id               Int      @id @default(autoincrement())
  carId            Int
  car              Car      @relation(fields: [carId], references: [id])
  submittedById    Int?
  submittedBy      User?    @relation(fields: [submittedById], references: [id])
  date             DateTime @default(now())
  fuelCost         Float
  pricePerLitre    Float
  odometer         Float
  litresRefueled   Float
  distanceTraveled Float
  consumptionRate  Float?
  isFullTank       Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AuditLog {
  id             Int          @id @default(autoincrement())
  action         String
  entityType     String
  entityId       Int
  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  details        String?      @db.Text
  createdAt      DateTime     @default(now())
}
